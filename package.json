{
  "name": "piece",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:backend\" \"pnpm run dev:frontend\" \"pnpm run dev:ws\"",
    "dev:backend": "./dev.sh",
    "dev:frontend": "pnpm exec nx run @piece/frontend:dev",
    "dev:ws": "cd apps/frontend/server && npx tsx src/index.ts",
    "build": "pnpm exec nx run-many -t build",
    "test": "pnpm exec nx run-many -t test",
    "lint": "pnpm exec nx run-many -t lint",
    "infra": "docker compose up -d mongodb redis nats minio qdrant postgres",
    "infra:stop": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "eslint": "^8.57.0",
    "nx": "^21.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "ua-parser-js": "^2.0.9"
  }
}
