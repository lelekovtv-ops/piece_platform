# piece — Staging Environment Template
# Copy this to .env and fill in actual values
# Generate secrets: openssl rand -hex 32

# ============================================================
# App
# ============================================================
NODE_ENV=production
LOG_LEVEL=info

# ============================================================
# MongoDB
# ============================================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_MONGO_PASSWORD
MONGODB_SYSTEM_DB=piece_system

# ============================================================
# JWT (generate: openssl genrsa 4096 > private.pem && openssl rsa -in private.pem -pubout > public.pem)
# Then base64-encode: cat private.pem | base64 -w 0 > private_b64.txt
# ============================================================
JWT_PUBLIC_KEY_BASE64=CHANGE_ME
JWT_PRIVATE_KEY_BASE64=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME_RANDOM_HEX_32

# ============================================================
# Security
# ============================================================
INTERNAL_TOKEN=CHANGE_ME_RANDOM_HEX_32
ENCRYPTION_KEY=CHANGE_ME_RANDOM_HEX_32

# ============================================================
# Email (disabled for staging — skip email verification)
# ============================================================
DISABLE_EMAIL_SENDING=true
FROM_EMAIL=noreply@staging.piece.io
FROM_NAME=PIECE Staging
SES_REGION=eu-central-1
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=

# ============================================================
# Frontend (set NEXT_PUBLIC_API_BASE_URL to http://<SERVER_IP>/api)
# ============================================================
NEXT_PUBLIC_API_BASE_URL=http://CHANGE_ME_SERVER_IP/api

# ============================================================
# Sentry (get DSN from sentry.io — free tier)
# ============================================================
SENTRY_DSN_BACKEND=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================
# PostHog (get key from posthog.com — free tier)
# ============================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# Grafana
# ============================================================
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ============================================================
# Ports (staging uses non-standard external ports)
# ============================================================
MONGO_PORT=27022
REDIS_PORT=6384
MINIO_API_PORT=9006
MINIO_CONSOLE_PORT=9007
NATS_PORT=4223
NATS_MONITOR_PORT=8223

# ============================================================
# GitHub Actions — Required Secrets & Variables
# ============================================================
# Add these in GitHub → Settings → Secrets and variables → Actions
#
# SECRETS (encrypted):
#   STAGE_HOST              — Staging server IP address
#   STAGE_USER              — SSH username (e.g. deploy)
#   STAGE_SSH_KEY           — SSH private key for staging server
#   MONGO_ROOT_USER         — MongoDB root username
#   MONGO_ROOT_PASSWORD     — MongoDB root password
#   JWT_PUBLIC_KEY_BASE64   — Base64-encoded RSA public key
#   JWT_PRIVATE_KEY_BASE64  — Base64-encoded RSA private key
#   JWT_REFRESH_SECRET      — Random hex (openssl rand -hex 32)
#   ENCRYPTION_KEY          — Random hex (openssl rand -hex 32)
#   INTERNAL_TOKEN          — Random hex (openssl rand -hex 32)
#   SES_ACCESS_KEY_ID       — AWS SES IAM access key (optional for staging)
#   SES_SECRET_ACCESS_KEY   — AWS SES IAM secret key (optional for staging)
#   SENTRY_DSN_BACKEND      — Sentry DSN for backend (optional)
#   NEXT_PUBLIC_SENTRY_DSN  — Sentry DSN for frontend (optional)
#   NEXT_PUBLIC_POSTHOG_KEY — PostHog project API key (optional)
#   GRAFANA_ADMIN_PASSWORD  — Grafana admin password
#
# VARIABLES (plaintext):
#   FROM_EMAIL              — noreply@staging.piece.io
#   FROM_NAME               — PIECE Staging
#   SES_REGION              — eu-central-1
#   SES_CONFIGURATION_SET   — (empty for staging)
